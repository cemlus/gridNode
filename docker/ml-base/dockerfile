FROM jupyter/scipy-notebook:python-3.11

USER root

RUN apt-get update && apt-get install -y --no-install-recommends \
    gcc \
    g++ \
    libgomp1 \
    git \
    && apt-get clean \
    && rm -rf /var/lib/apt/lists/*

USER $NB_UID

RUN pip install --no-cache-dir \
    papermill==2.5.0 \
    scikit-learn==1.4.0 \
    xgboost==2.0.3 \
    lightgbm==4.3.0 \
    pandas==2.2.0 \
    numpy==1.26.4 \
    matplotlib==3.8.2 \
    seaborn==0.13.2 \
    joblib==1.3.2 \
    pyarrow==15.0.0 \
    optuna==3.5.0 \
    mlflow==2.10.0

RUN papermill --version

WORKDIR /workspace